	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "ivrLogin (Security Token)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"#IV\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/security/ivrLogin/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"security",
								"ivrLogin",
								""
							]
						},
						"description": "Takes as input the username and returns an authorization token. The token is valid for up to 4 hours."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Test: Authentication endpoint",
									"pm.test('Status code is 200 OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has token', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('token');",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"    pm.expect(jsonData.token).to.have.length.above(0);",
									"});",
									"",
									"// Save token for subsequent requests",
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set('auth_token', jsonData.token);",
									"    // Token valid for 4 hours",
									"    const expiryTime = Date.now() + (4 * 60 * 60 * 1000);",
									"    pm.environment.set('token_expiry', expiryTime);",
									"    console.log('Auth token saved, expires in 4 hours');",
									"}"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Lookup & Query",
