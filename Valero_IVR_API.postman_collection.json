				{
					"name": "ANI (Lookup Account Number from ANI)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"brand\": \"Valero\",\n  \"ip_address\": \"{{ip_address}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/ivr_command/ani/:captured_ani",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"ivr_command",
								"ani",
								":captured_ani"
							],
							"variable": [
								{
									"key": "captured_ani",
									"value": "8005551234",
									"description": "The ANI (phone number) to lookup"
								}
							]
						},
						"description": "Takes in the ANI as input and returns the customer's account number. Returns account if the ANI is tied to a single account."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Test: ANI Lookup",
									"pm.test('Status code is 200 or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test('Response contains account information', function () {",
									"        const jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('account_number');",
									"    });",
									"    ",
									"    // Save account number for other tests",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set('found_account', jsonData.account_number);",
									"} else {",
									"    pm.test('404 response indicates ANI not found', function () {",
									"        pm.expect(pm.response.code).to.equal(404);",
									"    });",
									"}"
								]
							}
						}
					]
				},
