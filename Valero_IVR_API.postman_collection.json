					"// Test 2: Response should not be an error (4xx/5xx handled in specific tests)",
					"if (pm.response.code >= 200 && pm.response.code < 300) {",
					"    pm.test('Successful response (2xx)', function () {",
					"        pm.response.to.be.success;",
					"    });",
					"}",
					"",
					"// Test 3: Response should have proper content-type for JSON responses",
					"if (pm.response.headers.get('Content-Type')) {",
					"    const contentType = pm.response.headers.get('Content-Type');",
					"    if (contentType.includes('json')) {",
					"        pm.test('Response is JSON format', function () {",
					"            pm.response.to.be.json;",
					"        });",
					"    }",
					"}",
					"",
					"// Log response for debugging",
					"console.log('Response Status:', pm.response.code, pm.response.status);",
					"console.log('Response Time:', pm.response.responseTime + 'ms');"
				]
			}
		}
	]
}